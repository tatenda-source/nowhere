# === Nowhere — Production Environment ===
# Copy to .env and fill in real values before deploying.

# --- REQUIRED SECRETS (app will refuse to start without these) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
DEVICE_TOKEN_SECRET=
POSTGRES_PASSWORD=

# --- REDIS ---
REDIS_PASSWORD=changeme_to_strong_password

# --- CORS ---
# Comma-separated list of allowed origins (e.g. https://nowhere.app,https://www.nowhere.app)
ALLOWED_ORIGINS=https://nowhere.app

# --- DOMAIN (used by Caddy for automatic TLS) ---
NOWHERE_DOMAIN=nowhere.app

# --- OPTIONAL ---
DEBUG=false
POSTGRES_USER=postgres
POSTGRES_ENABLED=false
